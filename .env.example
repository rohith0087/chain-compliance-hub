# Public browser configuration. Never place Supabase secret/service-role keys in VITE_* variables.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
VITE_APP_ENV=development

# Edge Function secrets (configure in Supabase, not in browser builds).
APP_BASE_URL=http://localhost:5173
SYSTEM_INVOCATION_SECRET=replace_with_at_least_32_random_bytes
RESEND_API_KEY=re_replace_me
OPENAI_API_KEY=sk_replace_me
ELEVENLABS_API_KEY=replace_me
